# =========================================
# Coordex Environment Variables
# =========================================
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# ----- Database (PostgreSQL, e.g. Supabase) -----
# Pooled connection (untuk runtime; via pgbouncer). Contoh Supabase:
# postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Direct connection (untuk migrations & introspection). Contoh Supabase:
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ----- NextAuth (Auth.js v5) -----
# Base URL of the deployed app. Di Vercel, set ke https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Auth.js v5 juga menerima AUTH_SECRET
AUTH_SECRET=""

# ----- Supabase Storage -----
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role — JANGAN expose ke client. Set hanya di server env vars.
SUPABASE_SERVICE_ROLE_KEY=""
